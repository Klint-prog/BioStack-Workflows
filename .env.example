# BioStack Workflows Docker Platform Edition — phase_14
# Este arquivo contém apenas valores seguros de exemplo.

BIOSTACK_ENV=development
BIOSTACK_WORKSPACE=/workspace
BIOSTACK_DATABASE_URL=postgresql+psycopg://biostack:biostack@postgres:5432/biostack
BIOSTACK_REDIS_URL=redis://redis:6379/0
BIOSTACK_QUEUE_NAME=biostack:runs
BIOSTACK_LLM_PROVIDER=mock

POSTGRES_DB=biostack
POSTGRES_USER=biostack
POSTGRES_PASSWORD=biostack

API_PORT=8000
FRONTEND_PORT=5173
PLATFORM_PORT=8080

# Frontend local dev can override the relative API base if needed.
# VITE_API_BASE_URL=/api/v1

# Não defina chaves reais neste arquivo.
# BIOSTACK_LLM_API_KEY=
